# ─── Database ──────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/visutek"

# ─── Security ──────────────────────────────────────────────────────────────
# JWT secret — generate with: openssl rand -hex 32
JWT_SECRET="your-jwt-secret-here"

# AES-256 encryption key (for Shopify access tokens) — generate with: openssl rand -hex 32
ENCRYPTION_KEY="your-64-char-hex-key-here"

# ─── AWS / S3 ──────────────────────────────────────────────────────────────
# AWS credentials for S3 model storage
AWS_ACCESS_KEY_ID="your-access-key-id"
AWS_SECRET_ACCESS_KEY="your-secret-access-key"
AWS_REGION="us-east-1"
S3_BUCKET="visutek-models-prod"

# For Cloudflare R2 (S3-compatible, cheaper): uncomment and set endpoint
# S3_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"

# ─── Shopify ───────────────────────────────────────────────────────────────
# From your Shopify Partner dashboard → Apps → Your app
SHOPIFY_API_KEY="your-shopify-api-key"
SHOPIFY_API_SECRET="your-shopify-api-secret"

# Public hostname of the backend (no trailing slash)
HOST="https://app.visutek.io"

# ─── App URLs ──────────────────────────────────────────────────────────────
PORT=3001
ADMIN_URL="https://admin.visutek.io"

# ─── Environment ───────────────────────────────────────────────────────────
NODE_ENV="development"
