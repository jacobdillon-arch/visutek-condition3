{% comment %}
  VisuTek 3D Viewer — Theme App Extension Block

  Merchants add this block to their product page template via the Shopify Theme Editor.
  Set the "Viewer ID" setting to match the ID from the VisuTek admin dashboard.
{% endcomment %}

{%- if block.settings.viewer_id != blank -%}

<div
  class="visutek-viewer-wrap"
  data-visutek-config="{{ block.settings.viewer_id }}"
  style="
    width: 100%;
    height: {{ block.settings.height | default: 500 }}px;
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius | default: 0 }}px;
  "
  {{ block.shopify_attributes }}
>
  <iframe
    id="visutek-iframe-{{ block.id }}"
    src="{{ block.settings.api_url | default: 'https://app.visutek.io' }}/viewer?config={{ block.settings.viewer_id }}"
    style="width: 100%; height: 100%; border: none; display: block;"
    loading="lazy"
    title="{{ 'visutek.viewer_title' | t: default: '3D Product Viewer' }}"
    allow="accelerometer; autoplay"
  ></iframe>
</div>

<script>
(function() {
  var blockId = {{ block.id | json }};
  var iframe = document.getElementById('visutek-iframe-' + blockId);

  // Listen for postMessage events from the viewer iframe
  window.addEventListener('message', function(event) {
    // Only process VisuTek messages
    if (!event.data || typeof event.data !== 'object') return;
    var action = event.data.action;

    if (action === 'visutek:add_to_cart') {
      var variantId = event.data.variantId;
      var quantity = event.data.quantity || 1;
      if (!variantId) return;

      fetch(window.Shopify.routes.root + 'cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
        body: JSON.stringify({ items: [{ id: parseInt(variantId, 10), quantity: quantity }] })
      })
      .then(function(res) { return res.json(); })
      .then(function(data) {
        // Notify the cart — works with most themes (Dawn, Impulse, etc.)
        document.dispatchEvent(new CustomEvent('cart:refresh', { bubbles: true }));
        document.dispatchEvent(new CustomEvent('cart:updated', { bubbles: true, detail: { cart: data } }));

        // Dawn theme cart drawer
        var cartIconBubble = document.getElementById('cart-icon-bubble');
        if (cartIconBubble) {
          cartIconBubble.dispatchEvent(new CustomEvent('click'));
        }

        // Broadcast a generic cart update event (most third-party themes respond to this)
        window.dispatchEvent(new CustomEvent('visutek:cart-updated', { detail: { variantId: variantId, quantity: quantity } }));
      })
      .catch(function(err) {
        console.error('[VisuTek] Add to cart failed:', err);
      });
    }

    if (action === 'visutek:resize' && event.data.height) {
      var wrap = document.querySelector('[data-visutek-config="{{ block.settings.viewer_id }}"]');
      if (wrap) wrap.style.height = event.data.height + 'px';
    }
  });
})();
</script>

{%- else -%}

<div style="padding: 24px; background: #f9f9f9; border: 1px dashed #ccc; text-align: center; font-family: sans-serif; font-size: 13px; color: #888;">
  VisuTek 3D Viewer — set a Viewer ID in the block settings to activate.
</div>

{%- endif -%}

{% schema %}
{
  "name": "VisuTek 3D Viewer",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "viewer_id",
      "label": "Viewer ID",
      "info": "Copy the Viewer ID from your VisuTek dashboard → Viewers → Edit viewer"
    },
    {
      "type": "range",
      "id": "height",
      "label": "Viewer height (px)",
      "min": 300,
      "max": 900,
      "step": 50,
      "default": 500
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Corner radius (px)",
      "min": 0,
      "max": 24,
      "step": 2,
      "default": 0
    },
    {
      "type": "text",
      "id": "api_url",
      "label": "API URL (advanced)",
      "default": "https://app.visutek.io",
      "info": "Only change this if self-hosting VisuTek"
    }
  ],
  "presets": [
    {
      "name": "VisuTek 3D Viewer"
    }
  ]
}
{% endschema %}
